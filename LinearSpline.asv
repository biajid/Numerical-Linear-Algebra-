function yint = LinearSpline(x, y, xint)
% This function linear spline on x and y vector, and evaluates 
% the spline on xint to return yint.
n = length(x);

if n ~= length(y)
    error("Size Mismatch!");
end
x = x(:)';
y = y(:)';
xint = xint(:)';
yint = zeros(1, length(xint));

for m = 1 : length(xint)
    for i = 1 : n 
        if(xint(m) > x(i))
